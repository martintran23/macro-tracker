# --- Auth ---

@app.route("/api/auth/register", methods=["POST"])
def register():
    """Register a new user by email (no password needed for this project)."""
    data = request.get_json(force=True)
    err = validate_fields(data, ["email"])
    if err:
        return jsonify({"error": err}), 400

    db = get_db()
    try:
        db.execute("INSERT INTO users (email) VALUES (?)", (data["email"],))
        db.commit()
        user = db.execute("SELECT * FROM users WHERE email = ?", (data["email"],)).fetchone()
        return jsonify({"userId": user["id"], "email": user["email"]}), 201
    except sqlite3.IntegrityError:
        # User already exists — treat as login
        user = db.execute("SELECT * FROM users WHERE email = ?", (data["email"],)).fetchone()
        return jsonify({"userId": user["id"], "email": user["email"]}), 200


@app.route("/api/auth/login", methods=["POST"])
def login():
    """Look up a user by email."""
    data = request.get_json(force=True)
    err = validate_fields(data, ["email"])
    if err:
        return jsonify({"error": err}), 400

    db = get_db()
    user = db.execute("SELECT * FROM users WHERE email = ?", (data["email"],)).fetchone()
    if not user:
        return jsonify({"error": "User not found. Please register first."}), 404
    return jsonify({"userId": user["id"], "email": user["email"]}), 200


# --- Profile ---

@app.route("/api/profile/<int:user_id>", methods=["GET"])
def get_profile(user_id):
    db = get_db()
    row = db.execute("SELECT * FROM profiles WHERE user_id = ?", (user_id,)).fetchone()
    if not row:
        return jsonify({"error": "Profile not found"}), 404
    return jsonify(dict(row))


@app.route("/api/profile/<int:user_id>", methods=["POST", "PUT"])
def save_profile(user_id):
    data = request.get_json(force=True)
    err = validate_fields(data, ["weight", "height"])
    if err:
        return jsonify({"error": err}), 400

    db = get_db()
    db.execute("""
        INSERT INTO profiles (user_id, weight_kg, height_cm, updated_at)
        VALUES (?, ?, ?, datetime('now'))
        ON CONFLICT(user_id) DO UPDATE SET
            weight_kg  = excluded.weight_kg,
            height_cm  = excluded.height_cm,
            updated_at = excluded.updated_at
    """, (user_id, float(data["weight"]), float(data["height"])))
    db.commit()
    return jsonify({"message": "Profile saved"}), 200


