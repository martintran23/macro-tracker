@app.route("/api/log/<int:user_id>", methods=["GET"])
def get_logs(user_id):
    """Return the last 30 days of logs for progress tracking."""
    db = get_db()
    rows = db.execute("""
        SELECT * FROM daily_logs
        WHERE user_id = ?
        ORDER BY log_date DESC
        LIMIT 30
    """, (user_id,)).fetchall()
    return jsonify([dict(r) for r in rows])


# --- Recommendation (main pipeline) ---

@app.route("/api/recommendation", methods=["POST"])
def recommendation():
    """
    Main endpoint called by the React frontend (GoalsPage / InputPage).

    Expected JSON payload:
      weight, height, sleepQuality, dailyCalorieIntake,
      proteinIntake, workoutIntensity, goal
      userId (optional — if provided, result is persisted to DB)
    """
    data = request.get_json(force=True)
    required = [
        "weight", "height", "sleepQuality",
        "dailyCalorieIntake", "proteinIntake", "workoutIntensity",
    ]
    err = validate_fields(data, required)
    if err:
        return jsonify({"error": err}), 400

    try:
        result = run_pipeline(data)
    except Exception as e:
        return jsonify({"error": f"Inference failed: {str(e)}"}), 500

    # Persist recommendation if a userId was sent
    user_id = data.get("userId")
    if user_id:
        try:
            db = get_db()
            db.execute("""
                INSERT INTO recommendations
                    (user_id, workout_label, calories_target, protein_target,
                     carbs_target, fats_target)
                VALUES (?, ?, ?, ?, ?, ?)
            """, (
                int(user_id),
                result["workoutIntensity"],
                result["calories"],
                result["protein"],
                result["carbs"],
                result["fats"],
            ))
            db.commit()
        except Exception:
            pass  # Don't fail the request just because logging failed

    return jsonify(result), 200


